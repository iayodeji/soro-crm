rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All Firestore access (leads, sessions, team_knowledge) is performed
    // exclusively by the Next.js server via the Firebase Admin SDK, which
    // bypasses these rules entirely. No client SDK ever talks to Firestore
    // directly, so we deny all client reads/writes. Authentication is handled
    // server-side by the app (single default workspace), not by these rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
