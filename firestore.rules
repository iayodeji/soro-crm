rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/team_memberships/$(request.auth.uid + '_' + teamId));
    }

    function memberRole(teamId) {
      return get(/databases/$(database)/documents/team_memberships/$(request.auth.uid + '_' + teamId)).data.role;
    }

    function isTeamAdminOrOwner(teamId) {
      return isTeamMember(teamId) && memberRole(teamId) in ['owner', 'admin'];
    }

    function isTeamOwner(teamId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;
    }

    function hasPendingInvitation(token, teamId) {
      let invitePath = /databases/$(database)/documents/invitations/$(token);
      return token is string &&
        exists(invitePath) &&
        get(invitePath).data.status == 'pending' &&
        get(invitePath).data.teamId == teamId &&
        request.time < timestamp(get(invitePath).data.expiresAt) &&
        (get(invitePath).data.email == null ||
         get(invitePath).data.email == '' ||
         get(invitePath).data.email == request.auth.token.email);
    }

    // /teams/{teamId}
    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isSignedIn() &&
        request.resource.data.id == teamId &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isTeamAdminOrOwner(teamId);
      allow delete: if isTeamMember(teamId) && memberRole(teamId) == 'owner';
    }

    // /team_memberships/{userId}_{teamId}
    match /team_memberships/{membershipDocId} {
      // FIX: the "is this my own doc?" check now derives entirely from the doc ID
      // (membershipDocId == "{uid}_{teamId}") instead of resource.data.userId.
      // This matters because transaction.get() on this doc runs *before* the doc
      // exists (first-time join pre-check in joinTeamViaInvitation). On a
      // nonexistent doc, `resource` is null in security rules, so any reference
      // to resource.data throws -> Firestore reports "permission-denied" instead
      // of "not found". Deriving from the ID avoids touching resource.data at all
      // when the requester is checking their own membership.
      allow read: if isSignedIn() &&
        (
          (resource != null && resource.data.userId == request.auth.uid) ||
          membershipDocId.split('_')[0] == request.auth.uid ||
          isTeamMember(resource.data.teamId)
        );
      // A user can create their own membership (team creation, or accepting an invite)
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == request.auth.uid &&
        membershipDocId == request.auth.uid + '_' + request.resource.data.teamId &&
        (
          (isTeamOwner(request.resource.data.teamId) && request.resource.data.role == 'owner') ||
          hasPendingInvitation(request.resource.data.invitationToken, request.resource.data.teamId)
        );
      // Users can update their own presence/activity; admins/owners can change anyone's role
      allow update: if isSignedIn() &&
        (
          (resource.data.userId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'activity', 'lastActiveAt'])) ||
          isTeamAdminOrOwner(resource.data.teamId)
        );
      allow delete: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isTeamAdminOrOwner(resource.data.teamId));
    }

    // /leads/{leadId}
    match /leads/{leadId} {
      allow read, update, delete: if isTeamMember(resource.data.teamId);
      allow create: if isTeamMember(request.resource.data.teamId);
    }

    // /invitations/{token}
    match /invitations/{token} {
      allow get: if isSignedIn();
      allow create: if isTeamAdminOrOwner(request.resource.data.teamId);
      // FIX: open/link-based invites (empty or null email) can now also be marked
      // accepted/expired. Previously this required an exact email match, but
      // hasPendingInvitation() explicitly permits empty/null email to authorize
      // the join itself — so an open invite could let someone join and then fail
      // permission on the immediately-following status update in the same
      // transaction. Kept as a fallback; if every invite in your app always has
      // a concrete email attached, this branch simply never triggers.
      allow update: if isSignedIn() &&
        (resource.data.email == request.auth.token.email ||
         resource.data.email == null ||
         resource.data.email == '') &&
        resource.data.status == 'pending' &&
        request.resource.data.status in ['accepted', 'expired'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // /sessions/{sessionId}
    match /sessions/{sessionId} {
      allow read: if isTeamMember(resource.data.teamId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isTeamMember(resource.data.teamId) && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'summary', 'lastActivity', 'title']);
      allow delete: if isTeamMember(resource.data.teamId) && resource.data.userId == request.auth.uid;
    }

    // /team_knowledge/{teamId}
    match /team_knowledge/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isTeamAdminOrOwner(teamId);
      allow update: if isTeamAdminOrOwner(teamId);
      allow delete: if isTeamAdminOrOwner(teamId);
    }
  }
}
