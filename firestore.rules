rules_version = '2';
service cloudwarden.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(teamId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/team_memberships/$(request.auth.uid)_$(teamId)) &&
        get(/databases/$(database)/documents/team_memberships/$(request.auth.uid)_$(teamId)).data.role == 'owner';
    }

    function isAdmin(teamId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/team_memberships/$(request.auth.uid)_$(teamId)) &&
        get(/databases/$(database)/documents/team_memberships/$(request.auth.uid)_$(teamId)).data.role == 'admin';
    }

    function isMember(teamId) {
      return isSignedIn() && exists(/databases/$(database)/documents/team_memberships/$(request.auth.uid)_$(teamId));
    }

    function getRole(teamId) {
      return get(/databases/$(database)/documents/team_memberships/$(request.auth.uid)_$(teamId)).data.role;
    }

    function canWriteLeads(teamId) {
      return isMember(teamId) && getRole(teamId) != 'viewer';
    }

    // Teams Collection Rules
    match /teams/{teamId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(teamId);
      allow update: if isOwner(teamId) || isAdmin(teamId);
      allow delete: if isOwner(teamId);
    }

    // Team Memberships Collection Rules
    // Membership doc ID is formatted as userId_teamId
    match /team_memberships/{membershipId} {
      
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isMember(resource.data.teamId)
      );

      allow create: if isSignedIn() && (
        // Self-registration if they have an accepted invitation token
        request.resource.data.userId == request.auth.uid ||
        // Creator initial setup
        request.resource.data.userId == request.auth.uid && request.resource.data.role == 'owner' ||
        // Owner/Admin inviting someone
        isOwner(request.resource.data.teamId) || 
        (isAdmin(request.resource.data.teamId) && (request.resource.data.role == 'editor' || request.resource.data.role == 'viewer' || request.resource.data.role == 'member'))
      );

      allow update: if isSignedIn() && (
        // Owners can update any member role
        isOwner(resource.data.teamId) ||
        // Admins can update roles of editors/members/viewers, but NOT owners or other admins
        (isAdmin(resource.data.teamId) && 
         resource.data.role != 'owner' && 
         resource.data.role != 'admin' &&
         request.resource.data.role != 'owner' &&
         request.resource.data.role != 'admin'
        )
      );

      allow delete: if isSignedIn() && (
        // Owner can remove anyone except themselves (they must delete/transfer team)
        (isOwner(resource.data.teamId) && resource.data.userId != request.auth.uid) ||
        // Admins can remove editors/members/viewers, but NOT owners or other admins
        (isAdmin(resource.data.teamId) && resource.data.role != 'owner' && resource.data.role != 'admin') ||
        // Users can leave team voluntarily (self-delete)
        (resource.data.userId == request.auth.uid && resource.data.role != 'owner')
      );
    }

    // Leads Collection Rules
    match /leads/{leadId} {
      allow create: if isSignedIn() && canWriteLeads(request.resource.data.teamId);
      allow read: if isSignedIn() && isMember(resource.data.teamId);
      allow update: if isSignedIn() && canWriteLeads(resource.data.teamId) && (request.resource.data.teamId == resource.data.teamId);
      allow delete: if isSignedIn() && canWriteLeads(resource.data.teamId);
    }

    // Invitations Collection Rules (keyed by token)
    match /invitations/{token} {
      allow read: if true; // Public access to verify token on join
      allow create: if isSignedIn() && (
        isOwner(request.resource.data.teamId) ||
        (isAdmin(request.resource.data.teamId) && (request.resource.data.role == 'editor' || request.resource.data.role == 'viewer' || request.resource.data.role == 'member'))
      );
      allow update: if true; // Allow state transition to 'accepted' or 'expired'
      allow delete: if isSignedIn() && (isOwner(resource.data.teamId) || isAdmin(resource.data.teamId));
    }
  }
}
