# soroCRM or GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
soroCRM="MY_GEMINI_API_KEY"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional but strongly recommended production fallback for AI requests.
# Set one key, or a comma-separated pool of keys, server-side only.
GROQ_API_KEY="gsk_xxx"
# GROQ_API_KEYS="gsk_first,gsk_second"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Clerk (Auth + Team/Organization management — replaces Firebase Auth + Firestore)
# ---------------------------------------------------------------------------
# Publishable key (NEXT_PUBLIC so it is safe to expose to the browser).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
# Secret key — server only, never exposed to the client.
CLERK_SECRET_KEY="sk_test_xxx"
# Where Clerk-hosted auth pages live (used by the custom Sign-In button).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Google Workspace connection: enable the Google social connection in Clerk.
# In the Google Cloud project used by Clerk, enable Gmail API and Google Calendar
# API. The app requests only these user-approved scopes when they reconnect:
# https://www.googleapis.com/auth/gmail.send
# https://www.googleapis.com/auth/gmail.settings.basic (to choose verified From aliases)
# https://www.googleapis.com/auth/calendar.events
